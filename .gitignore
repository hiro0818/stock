# --- 機密分離 ---

# リクエスト(自分の投資方針が書いてある可能性)
inputs/*
!inputs/.gitkeep
!inputs/sample_request.md

# 自前で集めた決算メモ等
knowledge/*
!knowledge/.gitkeep

# 生成物(個別レポート)
outputs/*
!outputs/.gitkeep
# ただし PDCA 集計レポート + サマリ表は公開する(機密情報を含まない、実装精度の説明として有用)
!outputs/pdca_*.md
!outputs/v3_summary_table.md

# --- Claude Code ローカル個人設定 ---
.claude/settings.local.json

# --- Python ---
__pycache__/
*.pyc
.venv/
venv/

# --- Streamlit cache ---
.streamlit/secrets.toml

# --- OS / エディタ ---
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*~

# --- その他 ---
*.log
.env
.env.local
